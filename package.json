    "react-dom": "^18.2.0",
    "react-is": "^19.2.7",
    "sanity": "^3.99.0",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.14",
